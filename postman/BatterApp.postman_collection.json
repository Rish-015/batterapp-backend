{
  "info": {
    "name": "Batter App APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Full backend testing flow for Batter App."
  },
  "item": [
    {
      "name": "1. Send OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/send-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "send-otp"
          ]
        }
      }
    },
    {
      "name": "2. Verify OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.token) {",
              "  pm.environment.set(\"token\", json.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"{{otp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/verify-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "verify-otp"
          ]
        }
      }
    },
    {
      "name": "3. Get User Profile",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "me"
          ]
        }
      }
    },
    {
      "name": "4. Add Address",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address_text\": \"{{addressText}}\",\n  \"landmark\": \"{{landmark}}\",\n  \"lat\": {{lat}},\n  \"lng\": {{lng}},\n  \"is_default\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me/address",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "me",
            "address"
          ]
        }
      }
    },
    {
      "name": "5. Zone Detection",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.zoneId) {",
              "  pm.environment.set(\"zoneId\", json.zoneId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"lat\": {{lat}},\n  \"lng\": {{lng}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/zones/detect",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "zones",
            "detect"
          ]
        }
      }
    },
    {
      "name": "6. Get Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (Array.isArray(json) && json.length > 0) {",
              "  pm.environment.set(\"productId\", json[0]._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      }
    },
    {
      "name": "7. Slot Availability",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (Array.isArray(json) && json.length > 0) {",
              "  const first = json[0];",
              "  let slotId = null;",
              "  if (first.slotId && typeof first.slotId === \"object\" && first.slotId._id) {",
              "    slotId = first.slotId._id;",
              "  } else if (first.slotId) {",
              "    slotId = first.slotId;",
              "  } else if (first.slot_id) {",
              "    slotId = first.slot_id;",
              "  } else if (first._id) {",
              "    slotId = first._id;",
              "  }",
              "  if (slotId) {",
              "    pm.environment.set(\"slotId\", slotId);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/slot-availability?zoneId={{zoneId}}&date={{date}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "slot-availability"
          ],
          "query": [
            {
              "key": "zoneId",
              "value": "{{zoneId}}"
            },
            {
              "key": "date",
              "value": "{{date}}"
            }
          ]
        }
      }
    },
    {
      "name": "8. Create Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json._id) {",
              "  pm.environment.set(\"orderId\", json._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": {{quantity}},\n  \"slotId\": \"{{slotId}}\",\n  \"zoneId\": \"{{zoneId}}\",\n  \"paymentMode\": \"COD\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
      }
    },
    {
      "name": "9. Get Order Status",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}"
          ]
        }
      }
    }
  ]
}
